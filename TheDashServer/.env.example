# Copy this file to .env and fill in all values before starting the server.

# ── Server ──────────────────────────────────────────────────────────

# Port the server listens on
PORT=3100

# Password for the management web UI (required)
ADMIN_PASSWORD=change-me

# Secret used to sign session cookies — use a long random string (required)
SESSION_SECRET=change-me-to-a-long-random-string

# How many days deleted items stay in the archive before auto-purge
ARCHIVE_RETENTION_DAYS=30

# ── TLS / HTTPS ─────────────────────────────────────────────────────
# Paths to your TLS certificate and private key files.
# Generate a self-signed cert (dev/LAN):
#   mkdir ssl
#   openssl req -x509 -newkey rsa:4096 -keyout ssl/key.pem -out ssl/cert.pem -days 365 -nodes -subj "/CN=localhost"
# For production use Let's Encrypt (certbot).

SSL_KEY_PATH=./ssl/key.pem
SSL_CERT_PATH=./ssl/cert.pem

# ── MySQL / MariaDB ─────────────────────────────────────────────────

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=thedash
DB_PASSWORD=change-me
DB_NAME=thedash

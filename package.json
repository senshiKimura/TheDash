{
  "name": "thedash",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "electron-builder --win portable",
    "build:win": "electron-builder --win zip",
    "build:linux": "electron-builder --linux AppImage deb",
    "build:mac": "electron-builder --mac dmg"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "electron": "^41.6.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.thedash.app",
    "productName": "TheDash",
    "files": [
      "main.js",
      "preload.js",
      "mascot-preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "package.json",
      "assets/**"
    ],
    "win": {
      "icon": "assets/logo.png",
      "sign": null,
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "assets/logo.png",
      "category": "Utility",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ]
    },
    "mac": {
      "icon": "assets/logo.png",
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ]
    },
    "portable": {
      "artifactName": "TheDash.exe"
    }
  },
  "dependencies": {
    "googleapis": "^171.4.0"
  }
}
